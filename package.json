{
  "name": "expo-detect-carplay",
  "version": "1.0.3",
  "description": "Expo module for observing CarPlay and Android Auto connection state",
  "main": "build/cjs/index.js",
  "module": "build/index.js",
  "react-native": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "react-native": "./build/index.js",
      "import": "./build/index.js",
      "require": "./build/cjs/index.js",
      "default": "./build/index.js"
    },
    "./plugin": {
      "types": "./plugin/build/index.d.ts",
      "require": "./plugin/build/index.js",
      "default": "./plugin/build/index.js"
    },
    "./app.plugin": {
      "types": "./plugin/build/index.d.ts",
      "require": "./app.plugin.js",
      "default": "./app.plugin.js"
    },
    "./app.plugin.js": {
      "types": "./plugin/build/index.d.ts",
      "require": "./app.plugin.js",
      "default": "./app.plugin.js"
    }
  },
  "files": [
    "build/",
    "plugin/build/",
    "app.plugin.js",
    "docs/",
    "llms.txt",
    "ios/",
    "android/src/",
    "android/build.gradle",
    "expo-module.config.json",
    "src/",
    "!src/__tests__/"
  ],
  "scripts": {
    "build": "node internal/module_scripts/build.js && npm run build:cjs && npm run build:package-metadata && npm run build:plugin",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:package-metadata": "node scripts/write-build-package-metadata.cjs",
    "build:plugin": "node internal/module_scripts/build.js plugin",
    "docs:api": "typedoc --options typedoc.json && typedoc --options plugin/typedoc.json",
    "docs:check": "npm run docs:api && git diff --exit-code -- docs/reference",
    "test:types": "npm run build && tsc -p tests/consumer/tsconfig.json",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/ plugin/src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js && npm run build:cjs && npm run build:package-metadata",
    "prepublishOnly": "npm run prepare",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-detect-carplay",
    "ExpoDetectCarplay"
  ],
  "repository": "https://github.com/Mike89745/expo-detect-carplay",
  "bugs": {
    "url": "https://github.com/Mike89745/expo-detect-carplay/issues"
  },
  "author": "Martin Mikes <mikes89745@gmail.com> (https://github.com/Mike89745)",
  "license": "MIT",
  "homepage": "https://github.com/Mike89745/expo-detect-carplay#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^57.0.5",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.2"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    }
  },
  "peerDependencies": {
    "@expo/config-plugins": "*",
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
