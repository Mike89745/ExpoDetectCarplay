{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.json",
  "out": "../docs/reference/plugin",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "excludeInternal": true,
  "gitRevision": "master",
  "githubPages": false,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "invalidPath": true
  }
}
